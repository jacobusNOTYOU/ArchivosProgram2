//  Funcion que devuelve la cantidad de digitos
Cardinal CantDigitos(AnsiString nom)
{
	Cardinal c = 0;
	char x;
	fstream f(nom.c_str());
	if(!f.fail())
	{
		while(!f.eof())
		{
			x = f.get();
			if((x >= '0') && (x <= '9'))
			{
				c++;
			}
		}
		f.close();
    }
	return c;
}

