//  Funcion que devuelve la cantidad de espacios de un archivo de texto
Cardinal CantEspacios(AnsiString nom)
{
	Cardinal c = 0;
	char x;
	fstream f(nom.c_str()); //  Abir arch. por defecto en modo lectura, arch. Text
	if(!f.fail())
	{
		while(!f.eof())     //  pregunta si esta activa la bandera del eof
		{
			x = f.get();    //  devuelve el ele. apuntado y se pasa al siguiente
			if(x == ' ')    // lee el eol como un solo caracter
			{               //  cuando llega al eof el puntero se va a cualquierlado
				c++;        //  se activa la bandera eof i entrega basura
			}
		}
		f.close();
	}
	return c;
}

