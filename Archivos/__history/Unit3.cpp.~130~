//  Cambia numeros por 0
void ElimNum(AnsiString nom)
{
	char x;
	bool sw = true;
	fstream f(nom.c_str());
	fstream t("temporal.txt", ios::out);
	if(!f.fail())
	{
		while(!f.eof())
		{
			x = f.get();
			if(!f.eof())
			{
				if(isdigit(x))
				{
					if(sw)
					{
						t.put('0');
						sw = false;
					}
				}
				else
				{
					t.put(x);
					sw = true;
				}
			}
        }
		f.close();
		t.close();
		remove(nom.c_str());
		rename("temporal.txt", nom.c_str());
	}
}

