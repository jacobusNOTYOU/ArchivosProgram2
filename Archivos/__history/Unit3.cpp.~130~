	bool primer = false;
	fstream f(nom.c_str());
	fstream t("temporal.txt", ios::out);
	if(!f.fail())
	{
		while(!f.eof())
		{
			x = f.get();
			if(isgraph(x) && !primer)
				primer = true;
			if(primer && !f.eof())
			{
				t.put(x);
				if(x == '\n')
					primer = false;
			}
		}
		f.close();
		t.close();
