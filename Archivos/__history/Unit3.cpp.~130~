//  Elimina el primer numero de cada linea
void Eliminar1erNumeroDeCadaLinea(AnsiString nom)
{
	char e;
	bool primer = true;
	fstream f(nom.c_str());
	fstream t("temporal.txt", ios::out);
	if(!f.fail())
	{
		while(!f.eof())
		{
			e = f.get();
			if(((isdigit(e) && !primer) || !isdigit(e)) && !f.eof())
			{
				t.put(e);
			}
			else
			{
				if(!isdigit(f.peek()))
					primer = false;
			}
			if(e == '\n')
                primer = true;
		}
		f.close();
		t.close();
	}
	remove(nom.c_str());
	rename("temporal.txt", nom.c_str());
}

