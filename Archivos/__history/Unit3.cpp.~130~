//	Devuelve la longitud de la linea mas larga
int LongitudDeLineaMayor(AnsiString nom)
{
	int max = 0;
	int longitud = 0;
	char x;
	fstream f(nom.c_str());
	if(!f.fail())
	{
		while(!f.eof())
		{
			x = f.get();
			if(!(x == '\n') && !f.eof())
				longitud++;
			else
			{
				if(longitud > max)
					 max = longitud;
				longitud = 0;
			}
		}
		f.close();
	}
	return max;
}
