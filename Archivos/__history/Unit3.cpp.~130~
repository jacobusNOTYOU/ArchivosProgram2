bool EsMinuscula(char x)
{
	AnsiString letra("qwertyuiopasdfghjklzxcvbnmÛÈ·Ì˙Ò¸");
	return letra.Pos(x) > 0;
}

char Mayus(char x)
{
	// ¡…Õ—”⁄Ð·ÈÌÒÛ˙¸
	AnsiString min = "qwertyuiopasdfghjklzxcvbnm·ÈÌÒÛ˙¸";
	AnsiString may("QWERTYUIOPASDFGHJKLZXCVBNM¡…Õ—”⁄Ð");
	byte p = min.Pos(x);
	if(p>0)
		x = may[p];
	return x;
}
//  Counvierte las minusculas en mayusculas
void HacerMayusculas(AnsiString nom)
{
	char x;
	fstream f(nom.c_str(),ios::in | ios::out);  //Vamos a leer y grabar
	if(!f.fail())
	{
		while(!f.eof())
		{
			x = f.get();
			if(EsLetra(x))
			{
				if(EsMinuscula(x))
				{
					x = Mayus(x);
					f.seekg(-1, ios::cur);  //  ios::cur pos del puntero
					f.put(x);               //  El acceso ya no es secuencial.
					f.seekg(1, ios::cur);   //  Se lo vuelve secuencial al moverlo
					f.seekg(-1, ios::cur);  //  hacia adelante y hacia atras.
				}
			}
		}
		f.close();
    }
}

